global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - "/etc/prometheus/alert.rules.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

scrape_configs:
  - job_name: 'chiseongpa-nodes'
    scheme: https
    # 💡 Cloudflare Access를 통과하기 위한 '출입증' 제시
    headers:
      CF-Access-Client-Id: "{{ cf_client_id }}"
      CF-Access-Client-Secret: "{{ cf_client_secret }}"
    
    static_configs:
      - targets:
          # 💡 테라폼에서 생성한 GCP 메트릭용 도메인
          - "gcp-metrics.{{ app_domain }}"
          # 💡 만약 AWS 서브 서버도 도메인을 설정했다면 추가
          - "aws-metrics.{{ app_domain }}"

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']